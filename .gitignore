# live-build generated config (auto-created by lb config, not tracked)
build/config/bootstrap
build/config/chroot
build/config/binary
build/config/source
build/config/common

# live-build's stock hooks (symlinks to /usr/share/live/build/hooks/) —
# regenerated by lb config inside the container. Our own hooks have a
# leading 0xxx, 9990 prefix or descriptive name; lb's stock are 1000-1020,
# 5000-5050, 8000-8110, 9000-9020.
build/config/hooks/live/
build/config/hooks/normal/1000-*
build/config/hooks/normal/1010-*
build/config/hooks/normal/1020-*
build/config/hooks/normal/5000-*
build/config/hooks/normal/5010-*
build/config/hooks/normal/5020-*
build/config/hooks/normal/5030-*
build/config/hooks/normal/5040-*
build/config/hooks/normal/5050-*
build/config/hooks/normal/8000-*
build/config/hooks/normal/8010-*
build/config/hooks/normal/8020-*
build/config/hooks/normal/8030-*
build/config/hooks/normal/8040-*
build/config/hooks/normal/8050-*
build/config/hooks/normal/8060-*
build/config/hooks/normal/8070-*
build/config/hooks/normal/8080-*
build/config/hooks/normal/8090-*
build/config/hooks/normal/8100-*
build/config/hooks/normal/8110-*
build/config/hooks/normal/9000-*
build/config/hooks/normal/9010-*
build/config/hooks/normal/9020-*
build/config/package-lists/live.list.chroot

# live-build state and artifacts
build/.build/
build/chroot/
build/binary/
build/source/
build/cache/
build/build.log

# ISO output
output/
*.iso
*.img
*.zsync
*.tar
*.tar.gz

# Tool files cloned at first boot — not baked into git
build/config/includes.chroot/opt/venomOS/tools/

# OS artifacts
.DS_Store
Thumbs.db
*~
*.swp
