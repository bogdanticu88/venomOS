# Ensure shell scripts and Linux config files keep LF line endings
*.sh text eol=lf
*.chroot text eol=lf
*.conf text eol=lf
auto/config text eol=lf
build/auto/config text eol=lf

# Markdown and text files — auto
*.md text auto
*.xml text auto
*.toml text auto

# Binary files
*.iso binary
*.img binary
*.png binary
*.jpg binary
