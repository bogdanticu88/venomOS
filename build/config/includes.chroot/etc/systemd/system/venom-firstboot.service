[Unit]
Description=VenomOS first-boot setup (firewall, etc.)
After=network-online.target
Wants=network-online.target
ConditionPathExists=!/opt/venomOS/.firstboot-done

[Service]
Type=oneshot
ExecStart=/bin/bash -c 'ufw --force enable; mkdir -p /opt/venomOS && touch /opt/venomOS/.firstboot-done'
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
