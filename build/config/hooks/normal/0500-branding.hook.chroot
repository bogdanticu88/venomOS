#!/bin/bash
# VenomOS branding hook — runs inside chroot during ISO build.
# Removes Debian 13 identity and replaces with VenomOS throughout.
set -e

echo "[*] VenomOS: Applying system branding..."

# ── Identity files ────────────────────────────────────────────────────────────
# os-release and lsb-release are placed via includes.chroot;
# this hook double-stamps them in case any package postinst regenerated them.

cat > /etc/os-release << 'EOF'
NAME="VenomOS"
VERSION="1.0"
ID=venomos
ID_LIKE=debian
PRETTY_NAME="VenomOS 1.0"
VERSION_ID="1.0"
HOME_URL="https://github.com/bogdanticu88/venomOS"
SUPPORT_URL="https://github.com/bogdanticu88/venomOS/issues"
BUG_REPORT_URL="https://github.com/bogdanticu88/venomOS/issues"
ANSI_COLOR="0;32"
LOGO="venomos"
EOF

cat > /etc/lsb-release << 'EOF'
DISTRIB_ID=VenomOS
DISTRIB_RELEASE=1.0
DISTRIB_CODENAME=trixie
DISTRIB_DESCRIPTION="VenomOS 1.0"
EOF

# ── Hostname ──────────────────────────────────────────────────────────────────
echo "venomOS" > /etc/hostname
cat > /etc/hosts << 'EOF'
127.0.0.1   localhost
127.0.1.1   venomOS
::1         localhost ip6-localhost ip6-loopback
ff02::1     ip6-allnodes
ff02::2     ip6-allrouters
EOF

# ── MOTD ─────────────────────────────────────────────────────────────────────
cat > /etc/motd << 'EOF'

 __   _____ _  _  ___  __  __  ___  ___
 \ \ / / __| \| |/ _ \|  \/  |/ _ \/ __|
  \ V /| _|| .` | (_) | |\/| | (_) \__ \
   \_/ |___|_|\_|\___/|_|  |_|\___/|___/

  VenomOS 1.0 — Intelligence. Precision. Persistence.
  Run 'venom-help' to see available tools.
  Run 'sudo venom-setup' to install all tools on first boot.

EOF

# ── GRUB ─────────────────────────────────────────────────────────────────────
# Override GRUB_DISTRIBUTOR so update-grub uses VenomOS, not Debian
if [ -f /etc/default/grub ]; then
    sed -i 's/^GRUB_DISTRIBUTOR=.*/GRUB_DISTRIBUTOR="VenomOS"/' /etc/default/grub
    if ! grep -q 'GRUB_DISTRIBUTOR' /etc/default/grub; then
        echo 'GRUB_DISTRIBUTOR="VenomOS"' >> /etc/default/grub
    fi
    # Dark terminal colors as fallback if theme fails
    if ! grep -q 'GRUB_COLOR_NORMAL' /etc/default/grub; then
        echo 'GRUB_COLOR_NORMAL="green/black"'    >> /etc/default/grub
        echo 'GRUB_COLOR_HIGHLIGHT="white/green"' >> /etc/default/grub
    fi
fi

# Install VenomOS GRUB theme
if [ -d /usr/share/grub/themes/venomOS ]; then
    mkdir -p /boot/grub/themes
    cp -r /usr/share/grub/themes/venomOS /boot/grub/themes/venomOS

    if [ -f /etc/default/grub ]; then
        sed -i 's|^#*GRUB_THEME=.*|GRUB_THEME="/boot/grub/themes/venomOS/theme.txt"|' \
            /etc/default/grub
        if ! grep -q 'GRUB_THEME=' /etc/default/grub; then
            echo 'GRUB_THEME="/boot/grub/themes/venomOS/theme.txt"' >> /etc/default/grub
        fi
    fi
fi

# ── LightDM greeter ───────────────────────────────────────────────────────────
# Config placed via includes.chroot; ensure directories exist
mkdir -p /etc/lightdm

# Disable autologin (live-build sets it by default; explicit session login
# with the VenomOS greeter is better for the branding experience)
if [ -f /etc/lightdm/lightdm.conf ]; then
    sed -i 's/^autologin-user=.*/autologin-user=/' /etc/lightdm/lightdm.conf 2>/dev/null || true
fi

# ── Plymouth theme ────────────────────────────────────────────────────────────
if command -v plymouth-set-default-theme &>/dev/null; then
    if [ -f /usr/share/plymouth/themes/venomOS/venomOS.plymouth ]; then
        plymouth-set-default-theme venomOS 2>/dev/null || true
        echo "[+] Plymouth theme set to VenomOS"
    fi
fi

# ── Fastfetch system-wide preset ─────────────────────────────────────────────
if command -v fastfetch &>/dev/null; then
    mkdir -p /etc/fastfetch
    cat > /etc/fastfetch/config.jsonc << 'FASTFETCH_EOF'
{
  "logo": { "source": "venomos", "color": { "1": "green", "2": "red" } },
  "display": { "separator": "  ", "color": { "keys": "green", "values": "white" } },
  "modules": [
    "break",
    { "type": "os",       "key": "  OS      " },
    { "type": "kernel",   "key": "  Kernel  " },
    { "type": "uptime",   "key": "  Uptime  " },
    { "type": "shell",    "key": "  Shell   " },
    { "type": "de",       "key": "  DE      " },
    { "type": "terminal", "key": "  Term    " },
    { "type": "cpu",      "key": "  CPU     " },
    { "type": "memory",   "key": "  Memory  " },
    "break",
    { "type": "colors", "symbol": "block", "paddingLeft": 2 },
    "break"
  ]
}
FASTFETCH_EOF
fi

# ── Whiskermenu application name ─────────────────────────────────────────────
# Set panel button icon to the venomOS start-here icon path if it exists
mkdir -p /usr/share/icons/hicolor/scalable/apps

# ── XDG data dirs — add VenomOS app entries ───────────────────────────────────
mkdir -p /usr/share/applications

cat > /usr/share/applications/venom-setup.desktop << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=VenomOS Setup
Comment=Install all VenomOS tools (run once after first boot)
Exec=xfce4-terminal -e "sudo venom-setup"
Icon=system-software-install
Terminal=false
Categories=System;
EOF

cat > /usr/share/applications/venom-help.desktop << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=VenomOS Help
Comment=Show available VenomOS tools and commands
Exec=xfce4-terminal -e "venom-help"
Icon=help-browser
Terminal=false
Categories=System;
EOF

cat > /usr/share/applications/venom-ai.desktop << 'EOF'
[Desktop Entry]
Version=1.0
Type=Application
Name=VenomOS AI
Comment=Local AI analyst powered by Ollama
Exec=xfce4-terminal -e "venom-ai"
Icon=utilities-terminal
Terminal=false
Categories=System;Security;
EOF

echo "[+] VenomOS branding applied."
