#!/bin/sh
# live-build configuration for VenomOS Stage 1
# This script is called by build.sh and generates the lb config files.

lb config noauto \
    --distribution trixie \
    --archive-areas "main contrib non-free non-free-firmware" \
    --binary-images iso-hybrid \
    --bootloaders "grub-efi,grub-pc" \
    --bootappend-live "boot=live components splash quiet hostname=venomOS username=venom" \
    --bootappend-live-failsafe "boot=live components memtest noapic noapm nodma nomce nolapic nomodeset nosmp nosplash vga=normal" \
    --debian-installer none \
    --memtest none \
    --iso-application "VenomOS" \
    --iso-publisher "VenomOS Project" \
    --iso-volume "VENOMOS" \
    --security true \
    --updates true \
    "${@}"
